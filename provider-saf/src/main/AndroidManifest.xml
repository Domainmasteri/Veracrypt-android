<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!--
            VeraCrypt Documents Provider.
            Registered here so the host :app can declare the provider authority
            in its own manifest merge.
        -->
        <provider
            android:name=".VeraCryptDocumentsProvider"
            android:authorities="io.veracrypt.android.documents"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>
    </application>

</manifest>
